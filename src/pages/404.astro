---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout pageTitle="404 — Amir Mahdi Madani">
  <section class="flex flex-col items-start justify-center py-32">
    <p class="eyebrow">// 404</p>
    <h1 class="mt-5 text-5xl font-semibold text-[var(--accent)] glow-text sm:text-7xl">Signal lost</h1>
    <p class="mt-5 max-w-md text-[var(--muted)]">
      This route never made it past the betting table. Let's get you back to solid ground.
    </p>
    <a
      href="/"
      class="mt-8 rounded-md px-5 py-2.5 text-sm font-medium text-black"
      style="background: var(--accent); box-shadow: 0 0 24px -4px var(--accent);"
      >Return home</a
    >
  </section>
</BaseLayout>
